{
  "name": "pharmacare-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 execute pharmacare-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute pharmacare-db --remote --file=./migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute pharmacare-db --local --file=./migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute pharmacare-db --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "wrangler": "^3.99.0",
    "typescript": "^5.6.3",
    "@cloudflare/workers-types": "^4.20241127.0",
    "vitest": "^3.2.4"
  }
}
